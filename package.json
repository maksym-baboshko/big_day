{
  "name": "diandmax",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --config configs/vitest/config.ts --project unit",
    "test:watch": "vitest --config configs/vitest/config.ts --project unit",
    "test:storybook": "vitest run --config configs/vitest/config.ts --project storybook",
    "test:coverage": "vitest run --config configs/vitest/config.ts --project unit --coverage",
    "test:e2e": "playwright test --config configs/playwright/config.ts",
    "setup:browsers": "pnpm exec playwright install chromium",
    "smoke:history-restore:dev": "pnpm exec node e2e/smoke/dev-history-restore.mjs",
    "storybook": "HOME=\"$PWD/.cache/storybook/home\" STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -c configs/storybook -p 6006",
    "build-storybook": "HOME=\"$PWD/.cache/storybook/home\" STORYBOOK_DISABLE_TELEMETRY=1 storybook build -c configs/storybook -o artifacts/storybook/static",
    "chromatic": "HOME=\"$PWD/.cache/storybook/home\" STORYBOOK_DISABLE_TELEMETRY=1 chromatic --storybook-config-dir configs/storybook",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.477.0",
    "motion": "^12.7.2",
    "next": "16.2.1",
    "next-intl": "^4.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.51.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "chromatic": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "storybook": "^10.3.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["biome check --write --no-errors-on-unmatched"],
    "*.{json,css,md}": ["biome format --write --no-errors-on-unmatched"]
  },
  "pnpm": {
    "ignoredBuiltDependencies": ["sharp", "unrs-resolver"]
  }
}
